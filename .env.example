# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_URL=postgresql://user:password@localhost:5432/otto
POSTGRES_USER=otto_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=otto

# ── Qdrant ─────────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:8333
QDRANT_API_KEY=
QDRANT_COLLECTION=documents

# ── Redis (Upstash in prod) ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── LLM — Groq free tier (llama-3.3-70b-versatile) ───────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
LLM_MODEL=gemma2-9b-it
LLM_TEMPERATURE=0.2

# ── Embeddings & Reranker (downloaded at startup) ─────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ── Whisper STT ────────────────────────────────────────────────────────────────
WHISPER_MODEL=medium

# ── ElevenLabs TTS (English only) ─────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Redpanda / Kafka ───────────────────────────────────────────────────────────
REDPANDA_BROKERS=localhost:9092
REDPANDA_TOPIC_RAW=raw-documents
REDPANDA_GROUP_ID=ingestion-workers

# ── Monitoring ─────────────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=otto-rag

# ── App ────────────────────────────────────────────────────────────────────────
SESSION_TTL_SECONDS=1800
CORS_ORIGINS=http://localhost:3000
